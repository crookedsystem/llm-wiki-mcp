# Server
KB_HOST=127.0.0.1
KB_PORT=9999
KB_MCP_PATH=/mcp
KB_LOG_LEVEL=info

# Vault
KB_VAULT_PATH=/srv/kb/vault
KB_STATE_DB=/srv/kb/state/personal-kb.sqlite3
KB_MAX_NOTE_BYTES=102400

# Auth
KB_AUTH_MODE=bearer
KB_API_KEY=change-me-generate-a-long-random-token

# Writes / Git
KB_ENABLE_WRITES=true
KB_ENABLE_MOVE=true
KB_ENABLE_ARCHIVE=true
KB_ENABLE_HARD_DELETE=false
KB_REQUIRE_IF_HASH_FOR_UPDATES=true
KB_REQUIRE_PROVENANCE=true

# Vector DB extension point, disabled in v1
KB_VECTOR_ENABLED=false
KB_VECTOR_PROVIDER=none
KB_VECTOR_COLLECTION=personal_kb
KB_VECTOR_URL=
KB_EMBEDDING_PROVIDER=none
KB_EMBEDDING_MODEL=
